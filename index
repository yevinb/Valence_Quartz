    <script>
        // Initialize Stripe with YOUR specific Publishable Key
        const stripe = Stripe('pk_test_51TPIHsCS4Dl4b8aeS0Q8KaubCA1n30oe1s3GDKD5xoBBXjxqFbDZycsEJZVeQbmAehSTf3jJZkcO0dVEpQjoeYef00XecyicPR'); 
        const elements = stripe.elements();
        
        // Create and style the secure card input
        const style = {
          base: {
            color: '#0f172a',
            fontFamily: '"Plus Jakarta Sans", sans-serif',
            fontSmoothing: 'antialiased',
            fontSize: '14px',
            '::placeholder': { color: '#aab7c4' }
          },
          invalid: { color: '#ef4444', iconColor: '#ef4444' }
        };

        const card = elements.create('card', {style: style});
        card.mount('#card-element');

        // Handle validation errors in real-time
        card.on('change', function(event) {
          const displayError = document.getElementById('card-errors');
          if (event.error) {
            displayError.textContent = event.error.message;
          } else {
            displayError.textContent = '';
          }
        });

        // Function that runs when they click "Pay Securely"
        async function processPayment(cartTotal) {
            const displayError = document.getElementById('card-errors');
            
            // Prevent empty checkouts
            if (cartTotal <= 0) {
                displayError.textContent = "Your cart is currently empty.";
                return;
            }

            try {
                // A. Tell your backend to create a "Payment Intent" for the total amount
                const response = await fetch('/create-payment-intent', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ amount: cartTotal }) 
                });
                
                if (!response.ok) {
                    throw new Error("Could not connect to the backend server. Please ensure your backend is running.");
                }

                const { clientSecret } = await response.json();

                // B. Confirm the card payment directly with Stripe using the Secret
                const result = await stripe.confirmCardPayment(clientSecret, {
                    payment_method: {
                        card: card,
                    }
                });

                if (result.error) {
                    // The card was declined or there was an error
                    displayError.textContent = result.error.message;
                } else {
                    // SUCCESS! The payment went through.
                    if (result.paymentIntent.status === 'succeeded') {
                        alert('VQ Protocol: Payment successful! Funds have been secured.');
                    }
                }
            } catch (error) {
                console.error("Error processing payment:", error);
                displayError.textContent = "Server connection failed. Make sure your server.js file is actively running.";
            }
        }
    </script>
